{
  "name": "hearthkeep-web",
  "version": "0.4.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "python3 -m http.server 8000",
    "build": "echo 'Static — nothing to build.'",
    "cap-init": "npx -y @capacitor/cli init Hearthkeep com.hearthkeep.demo --web-dir .",
    "cap-add-android": "npx -y @capacitor/cli add android",
    "cap-sync": "npx -y @capacitor/cli sync android",
    "cap-open": "npx -y @capacitor/cli open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
