; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Hearthkeep"
config/description="HEARTHKEEP — 3D ARPG roguelike. Isometric Diablo-lineage camera, deep multiclassing, the player's Villa with Treasury chests + Trophy Hall set buffs, dragons (Vyxhasis, Ourzhal, Aethyrnax), goblin warbands, in-world gambling, armor dyes, Megabonk-style level-up perk cards, weapon evolutions, and a living-world simulation."
run/main_scene="res://scenes/title.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0.05, 0.04, 0.08, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

WorldLore="*res://scripts/world_lore.gd"
EventBus="*res://scripts/event_bus.gd"
GameState="*res://scripts/game_state.gd"
SaveSystem="*res://scripts/save/save_system.gd"
RunState="*res://scripts/run/run_state.gd"
LootSystem="*res://scripts/loot/loot_system.gd"
DyeSystem="*res://scripts/dyes/dye_system.gd"
Classes="*res://scripts/classes/class_db.gd"
TalentDB="*res://scripts/talents/talent_db.gd"
PerkPool="*res://scripts/perks/perk_pool.gd"
BuffSystem="*res://scripts/buffs/buff_system.gd"
VendorSystem="*res://scripts/economy/vendor_system.gd"
QuestSystem="*res://scripts/quests/quest_system.gd"
TravelSystem="*res://scripts/travel/travel_system.gd"
LoreCodex="*res://scripts/lore/lore_codex.gd"
WorldSim="*res://scripts/world/world_sim.gd"
WeatherSystem="*res://scripts/world/weather_system.gd"
EventDirector="*res://scripts/world/event_director.gd"
FactionState="*res://scripts/factions/faction_state.gd"
Towns="*res://scripts/towns/town_registry.gd"
Forge="*res://scripts/crafting/forge.gd"
NpcMemory="*res://scripts/npc/npc_memory.gd"
RumorPool="*res://scripts/npc/rumor_pool.gd"
SfxBus="*res://scripts/audio_bus.gd"
MusicDirector="*res://scripts/audio/music_director.gd"
VFX="*res://scripts/vfx/vfx_manager.gd"
OrientationMgr="*res://scripts/ui/orientation_manager.gd"
Inventory="*res://scripts/inventory/inventory.gd"
ChestManager="*res://scripts/storage/chest_manager.gd"
TrophyManager="*res://scripts/hall/trophy_manager.gd"
Settings="*res://scripts/settings.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="fractional"
window/handheld/orientation=1
window/handheld/display_cutout=2

