; Engine configuration file.
; Norrath Roguelike — Diablo-style mobile ARPG roguelike
; Generated for Godot 4.6.x

config_version=5

[application]

config/name="Norrath Roguelike"
config/description="Diablo-style mobile ARPG roguelike with deep multiclassing, base building, dragons, goblins, gambling, and Megabonk-style level-up perk loops."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"
boot_splash/show_image=false
boot_splash/bg_color=Color(0.05, 0.04, 0.08, 1)

[autoload]

GameState="*res://scripts/game_state.gd"
SaveSystem="*res://scripts/save/save_system.gd"
LootSystem="*res://scripts/loot/loot_system.gd"
RunState="*res://scripts/run/run_state.gd"
PerkPool="*res://scripts/perks/perk_pool.gd"
DyeSystem="*res://scripts/dyes/dye_system.gd"
ClassDB="*res://scripts/classes/class_db.gd"
TalentDB="*res://scripts/talents/talent_db.gd"
EventBus="*res://scripts/event_bus.gd"
VFX="*res://scripts/vfx/vfx_manager.gd"
SfxBus="*res://scripts/audio_bus.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/handheld/orientation=1
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

